{
  "manifest_version": 3,
  "name": "Hazakura Amp YouTube Remote",
  "version": "0.1.0",
  "description": "Shows a compact YouTube remote for Hazakura Amp boost and one-video repeat.",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Hazakura Amp"
  }
}
